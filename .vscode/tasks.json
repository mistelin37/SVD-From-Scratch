{
    "version": "2.0.0",
    "tasks": [
        {
            "label": "build current main",
            "type": "shell",
            "command": "g++",
            "args": [
                "-g",
                "${file}",                    // 当前打开的 main 文件
                "bmp.cpp",
                "svd.cpp",                    // 固定的源文件
                "-o",
                "${fileDirname}/${fileBasenameNoExtension}.exe"  // 输出与当前文件同名
            ],
            "group": {
                "kind": "build",
                "isDefault": true
            },
            "problemMatcher": ["$gcc"],
            "detail": "编译当前main文件和所有源文件"
        }
    ]
}